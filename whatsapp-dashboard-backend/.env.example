PORT=4000
NODE_ENV=development

# Postgres
DATABASE_URL=postgres://user:password@localhost:5432/whatsapp_dashboard

# Redis — reuse the same instance your WhatsApp automation backend already uses
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=replace-with-a-long-random-string
JWT_ACCESS_EXPIRES_IN=15m
REFRESH_TOKEN_DAYS=30

# Google OAuth 2.0 (optional; enables "Continue with Google")
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:4000/api/v1/auth/oauth/google/callback

# CORS — your TanStack Start frontend origin.
# For local dev: http://localhost:3000
# For deployed Lovable app via Cloudflare Tunnel: https://<your-app>.lovable.app
FRONTEND_ORIGIN=http://localhost:3000

# ─────────────────────────────────────────────────────────────
# Cloudflare Tunnel (recommended for exposing this backend
# to your deployed Lovable frontend without port-forwarding)
#
# 1. brew install cloudflared   (or platform equivalent)
# 2. cloudflared tunnel login
# 3. cloudflared tunnel create whatsapp-dashboard
# 4. cloudflared tunnel route dns whatsapp-dashboard api.yourdomain.com
# 5. Configure ~/.cloudflared/config.yml with:
#       ingress:
#         - hostname: api.yourdomain.com
#           service: http://localhost:4000
#         - service: http_status:404
# 6. cloudflared tunnel run whatsapp-dashboard
# 7. In the Lovable frontend env, set:
#       VITE_API_URL=https://api.yourdomain.com/api/v1
#       VITE_SOCKET_URL=https://api.yourdomain.com
# ─────────────────────────────────────────────────────────────

# WhatsApp webhook verification (Meta Cloud API / BSP) — reuse existing values
WHATSAPP_WEBHOOK_VERIFY_TOKEN=replace-me

# Internal bridge from your existing WhatsApp automation/webhook service
INTERNAL_INTEGRATION_TOKEN=replace-with-a-long-random-string

# Optional outbound bridge. If unset, dashboard sends are stored in Postgres only.
WHATSAPP_SEND_URL=http://localhost:5000/internal/whatsapp/send
WHATSAPP_SEND_TOKEN=replace-with-your-automation-service-token
WHATSAPP_SEND_STRICT=false
